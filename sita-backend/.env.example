NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sita_foundation
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=your_admin_jwt_secret_change_in_production
ADMIN_JWT_EXPIRES_IN=8h

# OTP (dev: OTP is logged to console, prod: use SMS provider)
OTP_EXPIRY_MINUTES=10
OTP_BYPASS=123456

# SITA Business Config
SITA_COMMISSION_PERCENT=2
MEMBERSHIP_FEE=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
